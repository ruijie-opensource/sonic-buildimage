From 5c0c462a0830b114fc155b1feb7c6649d117d3d7 Mon Sep 17 00:00:00 2001
From: ruijie-opensource <opensource@ruijie.com.cn>
Date: Tue, 1 Apr 2025 14:15:23 +0800
Subject: [PATCH] sonic-utilites-changes

---
 config/config_mgmt.py     | 11 ++++++++++-
 tests/config_mgmt_test.py |  2 +-
 2 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/config/config_mgmt.py b/config/config_mgmt.py
index 4e3115bd..52513a87 100644
--- a/config/config_mgmt.py
+++ b/config/config_mgmt.py
@@ -461,7 +461,16 @@ class ConfigMgmtDPB(ConfigMgmt):
             # Verify in Asic DB,
             self._verifyAsicDB(db=dataBase, ports=delPorts, portMap=if_name_map, \
                 timeout=MAX_WAIT)
-            self.writeConfigDB(addConfigtoLoad)
+            # The sequence cannot be guaranteed when the brk port written to the config db together
+            # port out of order will make err in sdk, so write each port individually 
+            ports = list(portJson['PORT'].keys())
+            for port in ports:
+                singleConfigtoLoad = dict()
+                tmp = dict()
+                tmp[port] = addConfigtoLoad['PORT'][port]
+                singleConfigtoLoad['PORT'] = tmp
+                self.writeConfigDB(singleConfigtoLoad)
+            # self.writeConfigDB(addConfigtoLoad)
 
         except Exception as e:
             self.sysLog(doPrint=True, logLevel=syslog.LOG_ERR, msg=str(e))
diff --git a/tests/config_mgmt_test.py b/tests/config_mgmt_test.py
index b09fdd6b..c4edb628 100644
--- a/tests/config_mgmt_test.py
+++ b/tests/config_mgmt_test.py
@@ -123,7 +123,7 @@ class TestConfigMgmt(TestCase):
             ['00:11:22:BB:CC:DD', '00:11:22:bb:cc:dd']
 
         # verify correct function call to writeConfigDB
-        assert cmdpb.writeConfigDB.call_count == 3
+        assert cmdpb.writeConfigDB.call_count == 4
         print(cmdpb.writeConfigDB.call_args_list[0])
         # args is populated if call is done as writeConfigDB(a, b), kwargs is
         # populated if call is done as writeConfigDB(A=a, B=b)
